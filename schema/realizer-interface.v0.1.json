{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ronviers/mpa-atlas/schema/realizer-interface.v0.1.json",
  "title": "MPA Realizer-Interface Document",
  "description": "MPA-RFC-RI v0.1 §2. Compilation output: spec × intent → R_doc. Cross-artifact predicates (RFC-RI §3 inv 4 / RFC-3 C-rules and K-rules) are validated against the constellation, not at the schema layer.",
  "type": "object",
  "required": [
    "spec_ref",
    "intent",
    "canonical_snapshot",
    "signature_targets",
    "acceptance",
    "realizer_class_target"
  ],
  "properties": {
    "spec_ref": { "type": "string" },
    "intent": { "enum": ["I1", "I2", "I3", "I4", "I5"] },
    "canonical_snapshot": {},
    "signature_targets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "fdr-signature.v0.1.json" }
    },
    "acceptance": {
      "type": "object",
      "required": ["forward_threshold", "round_trip_threshold"],
      "properties": {
        "forward_threshold": { "type": "number" },
        "round_trip_threshold": { "type": "number" }
      }
    },
    "realizer_class_target": { "type": "string" }
  }
}
