{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ronviers/mpa-atlas/schema/driver-profile.v0.2.json",
  "title": "MPA Driver Profile",
  "description": "MPA-RFC-S v0.2 §4. Substrate-class characterization. Field-level structure here is the canonical exchange shape; substrate-specific values (gamut envelopes, intent operations, reference_outputs content) are open-typed because they vary per substrate class.",
  "type": "object",
  "required": [
    "header",
    "operating_envelope",
    "gamut",
    "translation_field",
    "intents",
    "reference_outputs",
    "metadata"
  ],
  "properties": {
    "header": {
      "type": "object",
      "required": [
        "profile_version",
        "target_rfc_versions",
        "substrate_class",
        "characterization_date",
        "authority",
        "validation_history"
      ],
      "properties": {
        "profile_version": { "type": "string" },
        "target_rfc_versions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "substrate_class": { "type": "string" },
        "characterization_date": { "type": "string" },
        "authority": { "type": "string" },
        "validation_history": { "type": "array" }
      }
    },
    "operating_envelope": { "type": "object" },
    "gamut": { "type": "object" },
    "translation_field": { "type": "object" },
    "intents": {
      "type": "object",
      "patternProperties": {
        "^I[1-5]$": {
          "type": "object",
          "required": ["supported"],
          "properties": {
            "supported": { "type": "boolean" }
          }
        }
      },
      "additionalProperties": false
    },
    "reference_outputs": {
      "type": "array",
      "minItems": 1
    },
    "metadata": { "type": "object" }
  }
}
